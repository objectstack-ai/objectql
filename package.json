{
  "name": "objectql-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "objectstack serve --dev",
    "cli:dev": "ts-node packages/tools/cli/src/index.ts",
    "site:dev": "pnpm --filter @objectql/site run dev",
    "demo:dev": "pnpm --filter @objectql/demo run dev",
    "build": "turbo run build",
    "test": "pnpm run check-versions && turbo run test --concurrency=1",
    "lint": "turbo run lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "clean": "rm -rf dist packages/*/dist packages/*/node_modules node_modules",
    "site:build": "pnpm --filter @objectql/site run build",
    "site:start": "pnpm --filter @objectql/site run start",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "check-versions": "node scripts/check-versions.js",
    "analyze-deps": "node scripts/analyze-dependencies.js",
    "audit-coverage": "node scripts/audit-test-coverage.js",
    "bench:core": "tsx scripts/benchmarks/core-perf.ts",
    "bench:driver": "tsx scripts/benchmarks/driver-perf.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@object-ui/console": "^3.1.3",
    "@objectql/cli": "workspace:*",
    "@objectql/core": "workspace:*",
    "@objectql/driver-memory": "^4.2.2",
    "@objectql/driver-turso": "workspace:*",
    "@objectql/example-enterprise-erp": "workspace:*",
    "@objectql/example-project-tracker": "workspace:*",
    "@objectql/platform-node": "workspace:*",
    "@objectql/plugin-formula": "workspace:*",
    "@objectql/plugin-query": "workspace:*",
    "@objectql/plugin-security": "workspace:*",
    "@objectql/plugin-validator": "workspace:*",
    "@objectql/protocol-graphql": "workspace:*",
    "@objectql/protocol-json-rpc": "workspace:*",
    "@objectql/protocol-odata-v4": "workspace:*",
    "@objectstack/cli": "^3.2.9",
    "@objectstack/core": "^3.2.9",
    "@objectstack/objectql": "^3.2.9",
    "@objectstack/plugin-auth": "^3.2.9",
    "@objectstack/plugin-hono-server": "^3.2.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "js-yaml": "^4.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^1.6.1"
  },
  "version": "4.2.0",
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@objectql/protocol-json-rpc": "workspace:*",
    "@objectstack/studio": "^3.2.9",
    "build": "^0.1.4"
  }
}
