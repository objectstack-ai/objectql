{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --ignore-scripts",
  "buildCommand": "bash scripts/build-vercel.sh",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "{packages/*/dist,node_modules/@object-ui/console/dist,node_modules/@objectstack/plugin-auth/dist,node_modules/@objectstack/service-i18n/dist,node_modules/@objectstack/studio/dist,node_modules/@objectql/example-project-tracker/dist,node_modules/pino,node_modules/thread-stream,node_modules/sonic-boom,node_modules/pino-abstract-transport,node_modules/pino-std-serializers}/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[[...route]]" },
    { "source": "/(.*)", "destination": "/api/[[...route]]" }
  ]
}
